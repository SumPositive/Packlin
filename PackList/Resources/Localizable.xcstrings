    },
    "AI利用券が残っている間は購入できません、残りが0枚になってからご購入ください": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can't purchase while tickets remain; buy again when you have zero left."
