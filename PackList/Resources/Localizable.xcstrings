    "%@ を取り込みました" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has been imported!"
          }
        }
      }
    },
    "%@ を追加しました。アプリで内容を確認しましょう" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has been added. Check it in the app."
          }
        }
      }
    },
    "✔︎済（グループ内の必要なアイテムが全てチェック済み）" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Done (all required items in the group are checked)"
          }
        }
      }
    },
    "✔︎済（パック内の必要なアイテムが全てチェック済み）" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Done (all required items in the pack are checked)"
          }
        }
      }
    },
    "✔︎済（数量に関わらずチェック済みである）" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Done (checked regardless of quantity)"
          }
        }
      }
    },
    "AI利用が可能か確認できません。通信環境をご確認ください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can’t check if AI features are available right now. Please check your internet connection."
          }
        }
      }
    },
    "AI利用券が不足しています。下のメニューから購入してください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You’re out of AI tickets! Get more from the menu below."
          }
        }
      }
    },
    "AI利用券が残っている間は購入できません、残りが0枚になってからご購入ください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You still have some AI tickets left! You can buy more once your balance hits zero."
          }
        }
      }
    },
    "AI利用券が購入できませんでした、課金されません。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Couldn’t buy AI tickets. Don’t worry, you weren’t charged."
          }
        }
      }
    },
    "AI利用券の購入" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
