      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data may be corrupted.\nTapping \"Reset and Restart\" will back up the corrupted data,\nand the app will launch fresh on the next start.\n\nIf your packs are missing, restore from a backup."
          }
