    },
    "%@ を取り込みました" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has been imported!"
          }
        }
      }
    },
    "%@ を追加しました。アプリで内容を確認しましょう" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has been added. Check it in the app."
          }
        }
      }
    },
    "AI利用が可能か確認できません。通信環境をご確認ください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can’t check if AI features are available right now. Please check your internet connection."
          }
        }
      }
    },
    "AI利用券が不足しています。下のメニューから購入してください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You’re out of AI tickets! Get more from the menu below."
          }
        }
      }
    },
    "AI利用券が残っている間は購入できません、残りが0枚になってからご購入ください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You still have some AI tickets left! You can buy more once your balance hits zero."
          }
        }
      }
    },
    "AI利用券が購入できませんでした、課金されません。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Couldn’t buy AI tickets. Don’t worry, you weren’t charged."
          }
        }
      }
    },
    "AI利用券の購入" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Purchase AI Tickets"
          }
        }
      }
    },
    "AI利用券の購入中に問題が発生しました、課金されません。通信環境をご確認ください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We ran into a problem while purchasing AI tickets. You haven’t been charged. Please check your internet connection."
          }
        }
      }
    },
    "AI利用券は端末に安全に保管されますが、端末が壊れたりアプリを削除すると失われます。貯めずに早めにお使いください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your AI tickets are safely kept on this device, but they’ll be lost if you delete the app or your device breaks. Try to use them soon!"
          }
        }
      }
    },
    "AI利用券を%lld枚追加しました。" : {
      "localizations" : {
        "en" : {
