    "data.may.be.corrupted.tapping.reset" : {
      "comment" : "The text below the \"Reset and Restart\" button in the \"Database Error\" view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data may be corrupted.\nTapping \"Reset and Restart\" will back up the corrupted data,\nand the app will launch fresh on the next start.\n\nIf your packs are missing, restore from a backup."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データが破損している可能性があります。\n「リセットして再起動」をタップすると破損データを退避し、\n次回起動時にクリーンな状態でアプリが起動します。\n\nパックが消えた場合は、バックアップから復元してください。"
          }
        }
      }
    },
