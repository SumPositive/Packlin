    "packList.footer.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "* Tap the pack icon to edit its details\n* Tap the row to show the group list\n* Press and hold the row to drag and reorder\n* The pack icon status is shown as follows"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "・パックアイコンをタップすると内容を編集\n・行をタップするとグループ一覧を表示\n・行を長押しするとドラッグして並べ替え\n・パックアイコンの表示状況は下記の通り"
          }
        }
      }
    },
    "アイテムが見つかりません": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No items found."
          }
        }
      }
    },
    "アイテムを検索": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search items"
          }
        }
      }
    },
